groups = 1:p
glm_fit <- glm(standardise_out$y ~ as.matrix(standardise_out$X),family="binomial")
sgs = fit_sgs(X=X,y=y, groups=groups, type="logistic", lambda=0, alpha=1, vFDR=0.1, gFDR=0.1,intercept=TRUE,standardise="none")
ols_cost = sgs_convex_opt(X=X,y=y,beta=as.matrix(as.numeric(coef(glm_fit))),num_obs=n,gslope_seq=sgs$w_weights,slope_seq=sgs$v_weights,groups=c(0,groups))
sgs_cost = sgs_convex_opt(X=X,y=y,beta=as.matrix(sgs$beta),num_obs=n,gslope_seq=sgs$w_weights,slope_seq=sgs$v_weights,groups=c(0,groups))
expect_equivalent(coef(glm_fit),
as.matrix(sgs$beta),
tol = 1e-3
)
expect_equivalent(ols_cost, sgs_cost, tol=1e-3)
})
