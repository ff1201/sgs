X = scale(initX,scale=FALSE) # centering initX
if (family == "gaussian"){
out = hd_inference_gaussian(X, R, p, n, s, tau, cv, c, vMax, a, delta, verbose)
} else {
out = hd_inference_binomial_old(X, R, p, n_obs=n, n_trials, s, tau, cv, c, vMax, a, delta, verbose)
}
return(out)
}
hd_inference_gaussian <- function(X, R, p, n, s, tau, cv, c, vMax, a=1, delta=1, verbose=TRUE){
qOptArray = list() # for the purpose of the simulation it is helpful to store the optimum q. In practice this is not needed.
varbeta_hat = rep(0,vMax)
vBias = rep(0,vMax) # stores value of the bias at the optimum for each coeff
for (v in 1:vMax){
if (v %% 10 == 0 && verbose==TRUE){
print(v) # outputs progress after every 10 MC replicates
}
Xv = X[,v]
Xnotv = X[,-v]
M = Xnotv%*%t(Xnotv)
qOpt = a*solve(delta*diag(n)+M,Xv)
scale = t(qOpt)%*%Xv
toAdd = 0
for (j in 1:s){ # only signal variables (positions 1-5) contribute to the bias
if (j != v){ # if the vth variable is signal, omit this
Xj = X[,j]
toAdd = toAdd + (t(qOpt)%*%Xj)
}
}
vBias[v] = toAdd/scale
qOptArray[[v]] = qOpt
varbeta_hat[v] = tau*(t(qOpt)%*%qOpt)/((t(qOpt)%*%Xv)^2) # in practice tau needs to be estimated. We did this as in Appendix B. There are other options.
}
beta = c(rep(1,s),rep(0,p-s)) # sparse vector of true betas with the signal variables in positions 1-5.
beta_hat = matrix(0,nrow=R,ncol=vMax)
beta_upper = matrix(0,nrow=R,ncol=vMax)
beta_lower = matrix(0,nrow=R,ncol=vMax)
is_in_set = matrix(0,nrow=R,ncol=vMax)
for (r in 1:R){
if (r %% 10 == 0 && verbose==TRUE){
print(r) # outputs progress after every 10 MC replicates
}
epsilon = tau*rnorm(n)
Y = X%*%beta+epsilon
for (v in 1:vMax){
qOpt = qOptArray[[v]]
Xv = X[,v]
b = (t(qOpt)%*%Y)/(t(qOpt)%*%Xv)
beta_hat[r,v] = b
variance = varbeta_hat[v]
upper_limit = b + cv*sqrt(variance)
lower_limit = b - cv*sqrt(variance)
beta_upper[r,v] = upper_limit
beta_lower[r,v] = lower_limit
is_in_set[r,v] = (beta[v]>lower_limit)*(beta[v]<upper_limit) # for calculating the simulated coverage probability.
}
}
## Generate output
out = c()
out$beta_hat = beta_hat
out$beta_lower = beta_lower
out$beta_upper = beta_upper
out$is_in_set = is_in_set
out$mcProb = apply(is_in_set,2,mean)
out$vBias = vBias
out$varbeta_hat = varbeta_hat
out$qOptArray = qOptArray
out$modeMcProb = getmode(out$mcProb)
out$medianMcProb = median(out$mcProb)
meanWidth = apply(abs(beta_upper - beta_lower),2,mean)
out$medianWidth = median(meanWidth)
out$proportionGood = mean(out$mcProb>0.9)
out$proportionBad = 1-out$proportionGood
return(out)
}
hd_inference_binomial <- function(X, R, p, n_obs, n_trials, s, tau, cv, c, vMax, a=1, delta=1, verbose=TRUE){
varbeta_hat = matrix(0,nrow=R,ncol=vMax)
vBias = matrix(0,nrow=R,ncol=vMax) # stores value of the bias at the optimum for each coeff
beta = c(rep(1,s),rep(0,p-s)) # sparse vector of true betas with the signal variables in positions 1-5.
beta_hat = matrix(0,nrow=R,ncol=vMax)
beta_upper = matrix(0,nrow=R,ncol=vMax)
beta_lower = matrix(0,nrow=R,ncol=vMax)
is_in_set = matrix(0,nrow=R,ncol=vMax)
## Store repeated Matrix calculation
M_all = list()
for (v in 1:vMax){
M_all[[v]] = X[,-v]%*%t(X[,-v])
}
prob_y = apply(X, 1, function(x) exp(t(x)%*%beta)/(1+exp(t(x)%*%beta)))
for (r in 1:R){
response = rbinom(n=n_obs, size=n_trials, prob=prob_y)
empirical_log_transform = sapply(response, function(x) log((x+0.5)/(n_trials-x+0.5))) # applies the empirical logistic transformation
success_prob_est = (exp(empirical_log_transform))/(1+exp(empirical_log_transform)) # undoes the transformation to recover p, the success probability
eta_est = log(success_prob_est/(1-success_prob_est))
var_epsilon_diag = sapply(success_prob_est, function(x) (n_trials*x*(1-x))^-1)
exp_epsilon = sapply(success_prob_est, function(x) (2*x-1)/(2*n_trials*x*(1-x)))
var_epsilon = diag(sapply(success_prob_est, function(x) (n_trials*x*(1-x))^-1))
exp_epsilon_mult = exp_epsilon%*%t(exp_epsilon)
var_epsilon_mult = delta*var_epsilon
for (v in 1:vMax){
Xv = X[,v]
M = M_all[[v]]
qOpt = a*solve(var_epsilon_mult+exp_epsilon_mult+M,Xv)
scale = t(qOpt)%*%Xv
toAdd = 0
for (j in 1:s){ # only signal variables (positions 1-5) contribute to the bias
if (j != v){ # if the vth variable is signal, omit this
Xj = X[,j]
toAdd = toAdd + (t(qOpt)%*%Xj)
}
}
rem = (t(qOpt)%*%exp_epsilon)/as.numeric(t(qOpt)%*%Xv)
vBias[r,v] = toAdd/scale + rem
varbeta_hat[r,v] = tau*(t(qOpt)%*%qOpt)/((t(qOpt)%*%Xv)^2) # in practice tau needs to be estimated. We did this as in Appendix B. There are other options.
b = (t(qOpt)%*%eta_est)/(t(qOpt)%*%Xv)
beta_hat[r,v] = b
variance = varbeta_hat[r,v]
upper_limit = b + cv*sqrt(variance)
lower_limit = b - cv*sqrt(variance)
beta_upper[r,v] = upper_limit
beta_lower[r,v] = lower_limit
is_in_set[r,v] = (beta[v]>lower_limit)*(beta[v]<upper_limit) # for calculating the simulated coverage probability.
}
if (r %% 10 == 0 && verbose==TRUE){
print(paste0(r,"/",R)) # outputs progress after every 10 MC replicates
}
}
## Generate output
out = c()
out$beta_hat = beta_hat
out$beta_lower = beta_lower
out$beta_upper = beta_upper
out$is_in_set = is_in_set
out$mcProb = apply(is_in_set,2,mean)
out$vBias = vBias
out$varbeta_hat = varbeta_hat
out$modeMcProb = getmode(out$mcProb)
out$medianMcProb = median(out$mcProb)
meanWidth = apply(abs(beta_upper - beta_lower),2,mean)
out$medianWidth = median(meanWidth)
out$proportionGood = mean(out$mcProb>0.9)
out$proportionBad = 1-out$proportionGood
return(out)
}
hd_inference_binomial_old <- function(X, R, p, n_obs, n_trials, s, tau, cv, c, vMax, a=1, delta=1, verbose=TRUE){
varbeta_hat = matrix(0,nrow=R,ncol=vMax)
vBias = matrix(0,nrow=R,ncol=vMax) # stores value of the bias at the optimum for each coeff
beta = c(rep(0.7,s),rep(0.3,p-s)) # sparse vector of true betas with the signal variables in positions 1-5.
beta_hat = matrix(0,nrow=R,ncol=vMax)
beta_upper = matrix(0,nrow=R,ncol=vMax)
beta_lower = matrix(0,nrow=R,ncol=vMax)
is_in_set = matrix(0,nrow=R,ncol=vMax)
## Store repeated Matrix calculation
M_all = list()
for (v in 1:vMax){
M_all[[v]] = X[,-v]%*%t(X[,-v])
}
for (r in 1:R){
response = rbinom(n=n_obs, size=n_trials, prob=beta)
empirical_log_transform = sapply(response, function(x) log((x+0.5)/(n_trials-x+0.5))) # applies the empirical logistic transformation
success_prob_est = (exp(empirical_log_transform))/(1+exp(empirical_log_transform)) # undoes the transformation to recover p, the success probability
eta_est = log(success_prob_est/(1-success_prob_est))
var_epsilon_diag = sapply(success_prob_est, function(x) (n_trials*x*(1-x))^-1)
exp_epsilon = sapply(success_prob_est, function(x) (2*x-1)/(2*n_trials*x*(1-x)))
var_epsilon = diag(sapply(success_prob_est, function(x) (n_trials*x*(1-x))^-1))
exp_epsilon_mult = exp_epsilon%*%t(exp_epsilon)
var_epsilon_mult = delta*var_epsilon
for (v in 1:vMax){
Xv = X[,v]
M = M_all[[v]]
qOpt = a*solve(var_epsilon_mult+exp_epsilon_mult+M,Xv)
scale = t(qOpt)%*%Xv
toAdd = 0
for (j in 1:s){ # only signal variables (positions 1-5) contribute to the bias
if (j != v){ # if the vth variable is signal, omit this
Xj = X[,j]
toAdd = toAdd + (t(qOpt)%*%Xj)
}
}
rem = (t(qOpt)%*%exp_epsilon)/as.numeric(t(qOpt)%*%Xv)
vBias[r,v] = toAdd/scale + rem
varbeta_hat[r,v] = tau*(t(qOpt)%*%qOpt)/((t(qOpt)%*%Xv)^2) # in practice tau needs to be estimated. We did this as in Appendix B. There are other options.
b = (t(qOpt)%*%eta_est)/(t(qOpt)%*%Xv)
beta_hat[r,v] = b
variance = varbeta_hat[r,v]
upper_limit = b + cv*sqrt(variance)
lower_limit = b - cv*sqrt(variance)
beta_upper[r,v] = upper_limit
beta_lower[r,v] = lower_limit
is_in_set[r,v] = (beta[v]>lower_limit)*(beta[v]<upper_limit) # for calculating the simulated coverage probability.
}
if (r %% 10 == 0 && verbose==TRUE){
print(paste0(r,"/",R)) # outputs progress after every 10 MC replicates
}
}
## Generate output
out = c()
out$beta_hat = beta_hat
out$beta_lower = beta_lower
out$beta_upper = beta_upper
out$is_in_set = is_in_set
out$mcProb = apply(is_in_set,2,mean)
out$vBias = vBias
out$varbeta_hat = varbeta_hat
out$modeMcProb = getmode(out$mcProb)
out$medianMcProb = median(out$mcProb)
meanWidth = apply(abs(beta_upper - beta_lower),2,mean)
out$medianWidth = median(meanWidth)
out$proportionGood = mean(out$mcProb>0.9)
out$proportionBad = 1-out$proportionGood
return(out)
}
hd_inference_binomial_bootstrap <- function(X, R, p, n, s, tau, cv, c, vMax, a=1, delta=1, num_bootstrap = 1000, verbose=TRUE){
varbeta_hat = matrix(0,nrow=R,ncol=vMax)
vBias = matrix(0,nrow=R,ncol=vMax) # stores value of the bias at the optimum for each coeff
beta = c(rep(1,s),rep(0,p-s)) # sparse vector of true betas with the signal variables in positions 1-5.
beta_hat = matrix(0,nrow=R,ncol=vMax)
beta_upper = matrix(0,nrow=R,ncol=vMax)
beta_lower = matrix(0,nrow=R,ncol=vMax)
is_in_set = matrix(0,nrow=R,ncol=vMax)
for (r in 1:R){
# Bootstrap expectation and variance
success_prob_est = rep(0,n)
expEpsilon = rep(0,n)
varEpsilon = diag(n)
eta_est = rep(0,n)
yBootstrap = rep(0,n)
for (m in 1:num_bootstrap){
epsilon = tau*rnorm(n)
yBootstrap = yBootstrap + ifelse(sigmoid(X%*%beta+epsilon)>0.5,1,0) # calculate response #
}
success_prob_est = yBootstrap/num_bootstrap
success_prob_est = ifelse(success_prob_est==1,0.99,ifelse(success_prob_est==0,0.01,success_prob_est))
for (n_id in 1:n){
varEpsilon[n_id,n_id] = (num_bootstrap*success_prob_est[n_id]*(1-success_prob_est[n_id]))^(-1)
expEpsilon[n_id] = (2*success_prob_est[n_id]-1)/(2*num_bootstrap*success_prob_est[n_id]*(1-success_prob_est[n_id]))
eta_est[n_id] = log(success_prob_est[n_id]/(1-success_prob_est[n_id]))
}
expEpsilonMult = expEpsilon%*%t(expEpsilon)
varEpsilonMult = delta*varEpsilon
for (v in 1:vMax){
Xv = X[,v]
Xnotv = X[,-v]
M = Xnotv%*%t(Xnotv)
qOpt = a*solve(varEpsilonMult+expEpsilonMult+M,Xv)
scale = t(qOpt)%*%Xv
toAdd = 0
for (j in 1:s){ # only signal variables (positions 1-5) contribute to the bias
if (j != v){ # if the vth variable is signal, omit this
Xj = X[,j]
toAdd = toAdd + (t(qOpt)%*%Xj)
}
}
rem = (t(qOpt)%*%expEpsilon)/as.numeric(t(qOpt)%*%Xv)
vBias[r,v] = toAdd/scale + rem
varbeta_hat[r,v] = tau*(t(qOpt)%*%qOpt)/((t(qOpt)%*%Xv)^2) # in practice tau needs to be estimated. We did this as in Appendix B. There are other options.
b = (t(qOpt)%*%eta_est)/(t(qOpt)%*%Xv)
beta_hat[r,v] = b
variance = varbeta_hat[v]
upper_limit = b + cv*sqrt(variance)
lower_limit = b - cv*sqrt(variance)
beta_upper[r,v] = upper_limit
beta_lower[r,v] = lower_limit
is_in_set[r,v] = (beta[v]>lower_limit)*(beta[v]<upper_limit) # for calculating the simulated coverage probability.
}
if (r %% 10 == 0 && verbose==TRUE){
print(paste0(r,"/",R)) # outputs progress after every 10 MC replicates
}
}
## Generate output
out = c()
out$beta_hat = beta_hat
out$beta_lower = beta_lower
out$beta_upper = beta_upper
out$is_in_set = is_in_set
out$mcProb = apply(is_in_set,2,mean)
out$vBias = vBias
out$varbeta_hat = varbeta_hat
out$modeMcProb = getmode(out$mcProb)
out$medianMcProb = median(out$mcProb)
meanWidth = apply(abs(beta_upper - beta_lower),2,mean)
out$medianWidth = median(meanWidth)
out$proportionGood = mean(out$mcProb>0.9)
out$proportionBad = 1-out$proportionGood
return(out)
}
## Apply
R = 1000 # number of Monte Carlo replications
p = 2450 # number of potential explanatory variables
n = 70 # sample size
s = 5 # number of signal variables
tau = 1 # error variance
#cv = 1.96 # for nominal 95% coverage
cv = 2.575829
c = 0.9 # correlation between columns of X
vMax = 1000 # how many coefficients to calculate probabilities for (can set equal to p).
#output = hd_inference(R=R, p=p, n=n, s=s, tau=tau, cv=cv, c=c, vMax=vMax, family="gaussian")
output = hd_inference(R=R, p=p, n=n, s=s, tau=tau, cv=cv, c=c, vMax=vMax, family="binomial",verbose=TRUE)
output$proportionBad
output$proportionGood
output$medianWidth
